# No API key needed for match data — the backend auto-registers an account on first run.

# Card data via API-Football (free tier: 100 req/day)
# Register at https://dashboard.api-football.com/register then paste your key here:
# APIFOOTBALL_KEY=your_key_here
# You can override the credentials used if you want a specific account:
# WC_EMAIL=your@email.com
# WC_PASSWORD=YourPassword123

# TrueNAS / remote deploy: add your server IP so the browser can reach the backend
# CORS_ORIGINS=http://192.168.1.50:5173
